	<!-- ========================================== -->
	<!-- CAMERA PERMISSIONS (Existing) -->
	<!-- ========================================== -->

	<!-- Camera usage description -->
	<key>NSCameraUsageDescription</key>
	<string>Analog Intelligence needs camera access to scan film negatives and convert them to positive images.</string>

	<!-- Photo library usage (for saving exports) -->
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>Analog Intelligence needs permission to save your scanned and processed images to your photo library.</string>

	<key>NSPhotoLibraryUsageDescription</key>
	<string>Analog Intelligence needs access to your photo library to export processed images.</string>

	<!-- ========================================== -->
	<!-- APP CONFIGURATION (Existing) -->
	<!-- ========================================== -->

	<!-- Bundle Display Name -->
	<key>CFBundleDisplayName</key>
	<string>Analog Intelligence</string>

	<!-- Bundle Identifier -->
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>

	<!-- Version -->
	<key>CFBundleShortVersionString</key>
	<string>1.0</string>

	<key>CFBundleVersion</key>
	<string>1</string>

	<!-- Supported Interface Orientations -->
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>

	<!-- Launch Screen -->
	<key>UILaunchScreen</key>
	<dict>
		<key>UIImageName</key>
		<string>LaunchImage</string>
		<key>UIColorName</key>
		<string>LaunchScreenBackground</string>
	</dict>

	<!-- ========================================== -->
	<!-- NOTES -->
	<!-- ========================================== -->

	<!--
	BEFORE PRODUCTION RELEASE:
	1. Replace GADApplicationIdentifier with your actual AdMob App ID
	2. Download latest SKAdNetworkItems from: https://developers.google.com/admob/ios/3p-sdk-support
	3. Customize NSUserTrackingUsageDescription to match your privacy policy
	4. Test on both DEBUG and RELEASE builds
	5. Update privacy policy to disclose ad networks and data collection
	6. Configure Privacy Nutrition Label in App Store Connect

	For complete setup instructions, see ADMOB_SETUP.md
	-->
</dict>
</plist>
