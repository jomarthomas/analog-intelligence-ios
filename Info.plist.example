<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- ========================================== -->
	<!-- ADMOB CONFIGURATION -->
	<!-- ========================================== -->

	<!-- AdMob Application ID -->
	<!-- REQUIRED: Get this from AdMob dashboard after registering your app -->
	<!-- Format: ca-app-pub-XXXXXXXXXXXXXXXX~YYYYYYYYYY -->
	<key>GADApplicationIdentifier</key>
	<string>ca-app-pub-XXXXXXXXXXXXXXXX~YYYYYYYYYY</string>

	<!-- App Transport Security Settings -->
	<!-- REQUIRED: Allows AdMob to load ads from various sources -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<true/>
		<key>NSAllowsArbitraryLoadsForMedia</key>
		<true/>
		<key>NSAllowsArbitraryLoadsInWebContent</key>
		<true/>
	</dict>

	<!-- App Tracking Transparency -->
	<!-- REQUIRED for iOS 14+: Shown when requesting IDFA permission -->
	<!-- Customize message to explain why you need tracking permission -->
	<key>NSUserTrackingUsageDescription</key>
	<string>This app uses your advertising ID to provide personalized ads and measure ad performance. This helps support free features.</string>

